NODE_ENV=development

# Solana
SOLANA_CLUSTER=mainnet-beta
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=
SOLANA_RPC_FALLBACK_URLS=https://api.mainnet-beta.solana.com,https://solana.publicnode.com
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=
YELLOWSTONE_GRPC_ENDPOINT=
YELLOWSTONE_GRPC_TOKEN=

# Data stores
POSTGRES_URL=postgres://rayscan:rayscan@localhost:5432/rayscan
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=rayscan
CLICKHOUSE_PASSWORD=rayscan
REDIS_URL=redis://localhost:6379

# API
API_HOST=0.0.0.0
API_PORT=8080
API_TRUST_PROXY=false
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_RATE_LIMIT_PER_MIN=300
API_RATE_LIMIT_EXPENSIVE_PER_MIN=60
API_CACHE_MAX_ENTRIES=1000
GRAPHQL_MAX_COMPLEXITY=300
RATE_LIMIT_RPM_SOFT=300
RATE_LIMIT_RPM_HARD=1200
API_INTERNAL_URL=http://api:8080
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# Stream indexer
INDEXER_ENABLED=true
INDEXER_COMMITMENT=processed
INDEXER_RECONNECT_DELAY_MS=1500
INDEXER_PENDING_RECHECK_MS=2000
INDEXER_PENDING_BATCH_LIMIT=128
INDEXER_RPC_TIMEOUT_MS=12000

# Verifier
SOLANA_VERIFY_BIN=solana-verify
VERIFIER_BUILD_IMAGE=ghcr.io/ellipsis-labs/solana-verify:latest
VERIFIER_VERSION=dev
VERIFIER_HOST=127.0.0.1
VERIFIER_PORT=8081
VERIFIER_LOOP_INTERVAL_MS=500
VERIFIER_JOB_TIMEOUT_MS=180000
VERIFIER_LOG_MAX_BYTES=200000
# Set to enable manual trigger endpoint: /internal/v1/verifications/:programId/run
VERIFIER_INTERNAL_TOKEN=
